<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recess & Lunch Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #000000; font-family: 'Montserrat', sans-serif; color: #ffffff; padding: 24px; }
.container { max-width: 900px; margin: 0 auto; }
h1 { font-size: 18pt; font-weight: 800; text-align: center; border: 2px solid #cc0000; border-radius: 8px; padding: 14px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 24px; }
.tabs { display: flex; gap: 10px; margin-bottom: 20px; }
.tab-btn { flex: 1; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12pt; padding: 12px; background: #111111; border: 2px solid #333333; border-radius: 8px; color: #ffffff; cursor: pointer; text-transform: uppercase; }
.tab-btn.active { border-color: #cc0000; background: #1a0000; }
.panel { display: none; }
.panel.active { display: block; }
.card { background: #111111; border: 1px solid #222222; border-radius: 10px; padding: 18px; margin-bottom: 16px; }
.card h2 { font-size: 12pt; color: #cc0000; text-transform: uppercase; margin-bottom: 14px; letter-spacing: 0.5px; }
.form-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
input, select { font-family: 'Montserrat', sans-serif; background: #000000; border: 2px solid #333333; color: #ffffff; padding: 9px 10px; border-radius: 6px; font-size: 10.5pt; flex: 1; min-width: 120px; }
input:focus, select:focus { outline: none; border-color: #cc0000; }
button.primary { font-family: 'Montserrat', sans-serif; background: #cc0000; color: #fff; border: none; padding: 10px 18px; font-weight: 700; border-radius: 6px; cursor: pointer; text-transform: uppercase; font-size: 10.5pt; }
button.primary:hover { background: #ff1a1a; }
table { width: 100%; border-collapse: collapse; margin-top: 10px; }
th { text-align: left; font-size: 9.5pt; color: #cc0000; text-transform: uppercase; padding: 8px 6px; border-bottom: 2px solid #333333; }
td { padding: 6px; border-bottom: 1px solid #222222; }
td input { width: 100%; min-width: 90px; padding: 6px 8px; font-size: 10pt; }
.row-actions { display: flex; gap: 6px; }
button.save-btn, button.del-btn { font-family: 'Montserrat', sans-serif; border: none; padding: 6px 10px; border-radius: 5px; font-weight: 700; font-size: 9pt; cursor: pointer; text-transform: uppercase; }
button.save-btn { background: #2e7d32; color: #fff; }
button.save-btn:hover { background: #388e3c; }
button.del-btn { background: #444444; color: #fff; }
button.del-btn:hover { background: #cc0000; }
.status { text-align: center; font-size: 10pt; color: #888888; margin-top: 12px; min-height: 16px; }
.empty { text-align: center; color: #666; font-style: italic; padding: 16px; }
</style>
</head>
<body>
<div class="container">
  <h1>Recess & Lunch Manager</h1>

  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('recess')">Recess Locations</button>
    <button class="tab-btn" onclick="switchTab('lunch')">Lunch Pickup</button>
  </div>

  <!-- RECESS PANEL -->
  <div id="panel-recess" class="panel active">
    <div class="card">
      <h2>Add Recess Week</h2>
      <div class="form-row">
        <input type="date" id="r-start" placeholder="Start">
        <input type="date" id="r-end" placeholder="End">
        <input type="text" id="r-location" placeholder="Location (e.g. RIGHT Soccer Field)">
        <button class="primary" onclick="addRecess()">Add</button>
      </div>
    </div>
    <div class="card">
      <h2>Current Recess Schedule</h2>
      <table>
        <thead><tr><th>Start</th><th>End</th><th>Location</th><th></th></tr></thead>
        <tbody id="recess-tbody"></tbody>
      </table>
      <div class="empty" id="recess-empty" style="display:none;">No recess entries yet.</div>
    </div>
  </div>

  <!-- LUNCH PANEL -->
  <div id="panel-lunch" class="panel">
    <div class="card">
      <h2>Add Lunch Pickup Day</h2>
      <div class="form-row">
        <input type="date" id="l-date" placeholder="Date">
        <input type="text" id="l-provider" placeholder="Provider (e.g. Chick-fil-A)">
        <input type="text" id="l-student" placeholder="Student (e.g. Saja A)">
        <button class="primary" onclick="addLunch()">Add</button>
      </div>
    </div>
    <div class="card">
      <h2>Current Lunch Rotation</h2>
      <table>
        <thead><tr><th>Date</th><th>Provider</th><th>Student</th><th></th></tr></thead>
        <tbody id="lunch-tbody"></tbody>
      </table>
      <div class="empty" id="lunch-empty" style="display:none;">No lunch entries yet.</div>
    </div>
  </div>

  <div class="status" id="status"></div>
</div>

<script>
// ===== PASTE YOUR EXISTING FIREBASE CONFIG HERE (same one used in your other tools) =====
const firebaseConfig = {
  apiKey: "YOUR_API_KEY",
  authDomain: "bathroom-check-out.firebaseapp.com",
  databaseURL: "https://bathroom-check-out-default-rtdb.firebaseio.com",
  projectId: "bathroom-check-out",
  storageBucket: "bathroom-check-out.appspot.com",
  messagingSenderId: "YOUR_SENDER_ID",
  appId: "YOUR_APP_ID"
};
firebase.initializeApp(firebaseConfig);
const db = firebase.database();
const recessRef = db.ref("recessLocations");
const lunchRef = db.ref("lunchPickups");

function setStatus(msg) {
  document.getElementById("status").textContent = msg;
  setTimeout(() => { document.getElementById("status").textContent = ""; }, 2500);
}

function switchTab(tab) {
  document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.getElementById("panel-" + tab).classList.add("active");
  event.target.classList.add("active");
}

// ---------- RECESS ----------
function addRecess() {
  const start = document.getElementById("r-start").value;
  const end = document.getElementById("r-end").value;
  const location = document.getElementById("r-location").value.trim();
  if (!start || !end || !location) { setStatus("Fill in all recess fields."); return; }
  recessRef.push({ start, end, location });
  document.getElementById("r-start").value = "";
  document.getElementById("r-end").value = "";
  document.getElementById("r-location").value = "";
  setStatus("Recess week added.");
}

function saveRecess(id) {
  const start = document.getElementById(`r-start-${id}`).value;
  const end = document.getElementById(`r-end-${id}`).value;
  const location = document.getElementById(`r-loc-${id}`).value.trim();
  recessRef.child(id).update({ start, end, location });
  setStatus("Saved.");
}

function deleteRecess(id) {
  if (confirm("Delete this recess entry?")) recessRef.child(id).remove();
}

recessRef.on("value", snap => {
  const data = snap.val() || {};
  const entries = Object.entries(data).sort((a, b) => a[1].start.localeCompare(b[1].start));
  const tbody = document.getElementById("recess-tbody");
  const empty = document.getElementById("recess-empty");
  tbody.innerHTML = "";
  empty.style.display = entries.length ? "none" : "block";
  entries.forEach(([id, e]) => {
    const tr = document.createElement("tr");
    tr.innerHTML = `
      <td><input type="date" id="r-start-${id}" value="${e.start}"></td>
      <td><input type="date" id="r-end-${id}" value="${e.end}"></td>
      <td><input type="text" id="r-loc-${id}" value="${e.location}"></td>
      <td class="row-actions">
        <button class="save-btn" onclick="saveRecess('${id}')">Save</button>
        <button class="del-btn" onclick="deleteRecess('${id}')">Delete</button>
      </td>`;
    tbody.appendChild(tr);
  });
});

// ---------- LUNCH ----------
function addLunch() {
  const date = document.getElementById("l-date").value;
  const provider = document.getElementById("l-provider").value.trim();
  const student = document.getElementById("l-student").value.trim();
  if (!date || !provider || !student) { setStatus("Fill in all lunch fields."); return; }
  lunchRef.push({ date, provider, student });
  document.getElementById("l-date").value = "";
  document.getElementById("l-provider").value = "";
  document.getElementById("l-student").value = "";
  setStatus("Lunch day added.");
}

function saveLunch(id) {
  const date = document.getElementById(`l-date-${id}`).value;
  const provider = document.getElementById(`l-prov-${id}`).value.trim();
  const student = document.getElementById(`l-stu-${id}`).value.trim();
  lunchRef.child(id).update({ date, provider, student });
  setStatus("Saved.");
}

function deleteLunch(id) {
  if (confirm("Delete this lunch entry?")) lunchRef.child(id).remove();
}

lunchRef.on("value", snap => {
  const data = snap.val() || {};
  const entries = Object.entries(data).sort((a, b) => a[1].date.localeCompare(b[1].date));
  const tbody = document.getElementById("lunch-tbody");
  const empty = document.getElementById("lunch-empty");
  tbody.innerHTML = "";
  empty.style.display = entries.length ? "none" : "block";
  entries.forEach(([id, e]) => {
    const tr = document.createElement("tr");
    tr.innerHTML = `
      <td><input type="date" id="l-date-${id}" value="${e.date}"></td>
      <td><input type="text" id="l-prov-${id}" value="${e.provider}"></td>
      <td><input type="text" id="l-stu-${id}" value="${e.student}"></td>
      <td class="row-actions">
        <button class="save-btn" onclick="saveLunch('${id}')">Save</button>
        <button class="del-btn" onclick="deleteLunch('${id}')">Delete</button>
      </td>`;
    tbody.appendChild(tr);
  });
});
</script>
</body>
</html>
